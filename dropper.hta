<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="x-ua-compatible" content="IE=edge">
    <title>My App</title>
    
    <!-- Optional: HTA application header configuration -->
    <hta:application id="myApp" applicationname="MyApp" scroll="no" singleinstance="yes" />

    <style>
        html, body { width: 100%; height: 100%; margin: 0; padding: 0; background: #f0f0f0; }
        #dropzone { 
            width: 80%; height: 200px; margin: 40px auto; 
            border: 3px dashed #666; background: #fff;
            text-align: center; line-height: 200px; font-family: sans-serif;
        }
    </style>
</head>

<!-- 
  CRITICAL FIX: Inline handlers on the body capture and kill the OS-level shell command.
  "return false;" here prevents mshta.exe from processing the file redirect.
-->
<body ondragenter="return false;" ondragover="return false;" ondrop="return false;">

    <!-- The actual area you want users to drop into -->
    <div id="dropzone">Drop your file directly here</div>

    <script>
        // 1. Kill everything globally via Javascript for double insurance
        var killEvent = function(e) {
            e = e || window.event;
            if (e.preventDefault) e.preventDefault();
            if (e.stopPropagation) e.stopPropagation();
            e.returnValue = false;
            return false;
        };

        window.addEventListener("dragenter", killEvent, false);
        window.addEventListener("dragover", killEvent, false);
        window.addEventListener("drop", killEvent, false);
        document.addEventListener("drop", killEvent, false);

        // 2. Safely capture the file inside the specific dropzone div element
        var dropzone = document.getElementById("dropzone");

        dropzone.addEventListener("dragover", function(e) {
            e.preventDefault();
            e.returnValue = false;
        }, false);

        dropzone.addEventListener("drop", function(e) {
            // Prevent execution bubble up to the body/window
            e.preventDefault();
            if (e.stopPropagation) e.stopPropagation();
            e.returnValue = false;

            // Access the file tracking data cleanly
            var files = e.dataTransfer.files;
            if (files && files.length > 0) {
                var file = files[0];
                dropzone.innerHTML = "Processing: " + file.name;
                
                // Trigger your Base64 FileReader or file workflow safely here!
                console.log("File detected successfully without crash.");
            }
            return false;
        }, false);
    </script>
</body>
</html>
