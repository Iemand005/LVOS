<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="x-ua-compatible" content="IE=edge">
    <title>My Protected App</title>
    <hta:application id="oApp" applicationname="DropApp" scroll="no" windowstate="normal" />
    
    <style>
        html, body { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #fff; }
        /* Style the wrapper container holding our modern browser object */
        #browserContainer { width: 100%; height: 100%; }
    </style>
</head>
<body>

    <!-- 1. Use the native Windows Shell Explorer instead of a normal iframe -->
    <object id="wb" classid="clsid:8856F961-340A-11D0-A96B-00C04FD705A2" style="width:100%; height:100%;">
        <param name="RegisterAsBrowser" value="1">
        <param name="RegisterAsDropTarget" value="1">
    </object>

    <script>
        // 2. Point the WebBrowser control to your internal content page
        window.onload = function() {
            // RegisterAsDropTarget=true makes this control absorb shell drops safely
            wb.RegisterAsDropTarget = true; 
            
            // Navigate to your actual user interface file (create this app_content.html file next)
            wb.Navigate(location.href.replace(/[^\/\\]+$/, "") + "index.html");
            
            // Hook into the navigation engine to flat-out block any file redirects
            wb.BeforeNavigate2 = function(pDisp, URL, Flags, TargetFrameName, PostData, Headers, Cancel) {
                // If it tries to navigate away to a local file, cancel it immediately
                if (URL.indexOf("index.html") === -1) {
                    // Setting Cancel to true drops the OS navigation process
                    Cancel = true; 
                    alert("Redirect blocked! Pass the URL to JS instead: " + URL);
                }
            };
        };
    </script>

</body>
</html>
