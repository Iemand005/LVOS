<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="x-ua-compatible" content="IE=edge">
    <title>My Drop-Enabled App</title>
    <hta:application id="oApp" applicationname="DropFix" scroll="no" windowstate="normal" />
    <style>
        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; }
    </style>
</head>
<body ondragenter="alert('body ondragenter')" ondragover="event.preventDefault();" ondrop="alert('body ondrop'); event.preventDefault();">

    <!-- The ActiveX browser control is used to capture native file drops in HTA. -->
    <object id="wb" classid="clsid:8856F961-340A-11D0-A96B-00C04FD705A2" style="position:absolute;top:0;left:0;width:100%;height:100%;">
        <param name="RegisterAsBrowser" value="1">
        <param name="RegisterAsDropTarget" value="1">
    </object>

    <script>
        function getFileUrl(filePath) {
            if (!filePath) return filePath;
            if (/^[a-zA-Z][a-zA-Z0-9+.-]*:/.test(filePath)) return filePath;
            return 'file:///' + filePath.replace(/\\/g, '/');
        }

        function beforeNavigateHandler(pDisp, URL, Flags, TargetFrameName, PostData, Headers, Cancel) {
            if (!URL) return true;
            var normalized = URL.toString();
            if (normalized.toLowerCase().indexOf('index.html') !== -1 || normalized.toLowerCase().indexOf('about:blank') !== -1) {
                return true;
            }
            alert('Drop detected via BeforeNavigate2: ' + normalized);
            try {
                if (Cancel != null) {
                    if (typeof Cancel === 'object') Cancel.value = true;
                    else Cancel = true;
                }
            } catch (e) {
                try {
                    Cancel.value = true;
                } catch (e2) {}
            }
            if (window.event) {
                try { window.event.returnValue = false; } catch (e) {}
            }
            try {
                if (wb && wb.Document && wb.Document.parentWindow && typeof wb.Document.parentWindow.handleDroppedFilePath === 'function') {
                    wb.Document.parentWindow.handleDroppedFilePath(normalized);
                }
            } catch (e) {
                console.warn('Failed to forward dropped file path:', e);
            }
            return false;
        }

        window.onload = function() {
            wb.RegisterAsBrowser = 1;
            wb.RegisterAsDropTarget = 1;
            wb.Navigate('index.html');
            if (wb.attachEvent) {
                wb.attachEvent('onbeforenavigate2', beforeNavigateHandler);
            } else if (wb.addEventListener) {
                wb.addEventListener('BeforeNavigate2', beforeNavigateHandler, false);
            } else {
                wb.onbeforenavigate2 = beforeNavigateHandler;
            }
        };
    </script>
</body>
</html>
