<!DOCTYPE html>
<html>
<head>
    <title>HTA Drop Fix – No White Screen</title>
    <HTA:APPLICATION ID="app" APPLICATIONNAME="DropTest" />
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        html, body { width:100%; height:100%; overflow:hidden; }
        #container { position:relative; width:100%; height:100%; }
        iframe { position:absolute; top:0; left:0; width:100%; height:100%; border:none; background:red; }
        #blocker { position:absolute; top:0; left:0; width:100%; height:100%; background:rgba(0, 255, 4, 0.011); z-index:9999; pointer-events:auto; }
    </style>
</head>
<body>
<div id="container">
    <iframe id="myFrame" src="about:blank"></iframe>
    <div id="blocker"></div>
</div>

<script>
    // Create iframe content (no backticks, old‑IE compatible)
    var iframe = document.getElementById('myFrame');
    var iframeDoc = iframe.contentWindow.document;
    iframeDoc.open();
    iframeDoc.write(
        '<!DOCTYPE html>' +
        '<html>' +
        '<head>' +
        '<style>' +
        'body { font-family: Arial; padding: 20px; background: #f5f5f5; }' +
        '.dropzone { border: 3px dashed #aaa; border-radius: 12px; padding: 40px; text-align: center; background: white; transition: all 0.2s; }' +
        '.dropzone.drag-over { border-color: #0078d7; background: #e5f0ff; }' +
        '#output { margin-top: 20px; padding: 10px; background: white; border: 1px solid #ccc; border-radius: 8px; font-family: monospace; white-space: pre-wrap; }' +
        '</style>' +
        '</head>' +
        '<body>' +
        '<div class="dropzone" id="dropzone">' +
        '<h2>Drop files or text here</h2>' +
        '<p>Drag from desktop, Explorer, or any text</p>' +
        '</div>' +
        '<div id="output">Waiting for drop...</div>' +
        '<script>' +
        'var dropzone = document.getElementById("dropzone");' +
        'var output = document.getElementById("output");' +
        'window.addEventListener("message", function(e) {' +
        '    var data = e.data;' +
        '    if (data && data.type === "drop") {' +
        '        dropzone.classList.remove("drag-over");' +
        '        output.innerHTML = "";' +
        '        if (data.files && data.files.length > 0) {' +
        '            output.innerHTML += "<strong>Files:</strong><ul>";' +
        '            for (var i = 0; i < data.files.length; i++) {' +
        '                var f = data.files[i];' +
        '                output.innerHTML += "<li>" + f.name + " (" + (f.size || "?") + " bytes)</li>";' +
        '                var reader = new FileReader();' +
        '                reader.onload = (function(fileName) {' +
        '                    return function(ev) {' +
        '                        output.innerHTML += "<div><strong>Content of " + fileName + ":</strong><pre>" + ev.target.result + "</pre></div>";' +
        '                    };' +
        '                })(f.name);' +
        '                reader.readAsText(f, "UTF-8");' +
        '            }' +
        '            output.innerHTML += "</ul>";' +
        '        }' +
        '        if (data.text) {' +
        '            output.innerHTML += "<strong>Plain text:</strong><pre>" + data.text + "</pre>";' +
        '        }' +
        '        if (data.html && !data.text) {' +
        '            output.innerHTML += "<strong>HTML:</strong><pre>" + data.html.replace(/</g, "&lt;") + "</pre>";' +
        '        }' +
        '        if (!data.files.length && !data.text && !data.html) {' +
        '            output.innerHTML = "No data received.";' +
        '        }' +
        '    } else if (data && data.type === "dragenter") {' +
        '        dropzone.classList.add("drag-over");' +
        '    } else if (data && data.type === "dragleave") {' +
        '        dropzone.classList.remove("drag-over");' +
        '    }' +
        '});' +
        'window.parent.postMessage({ type: "ready" }, "*");' +
        '<\/script>' +
        '</body>' +
        '</html>'
    );
    iframeDoc.close();

    // ========== CRITICAL: Robust event killer for IE/HTA ==========
    function killEvent(e) {
        // Get the actual event object (IE uses window.event, modern uses parameter)
        var evt = e || window.event;
        if (evt) {
            if (evt.preventDefault) evt.preventDefault();
            if (evt.stopPropagation) evt.stopPropagation();
            evt.returnValue = false;
            evt.cancelBubble = true;
        }
        // Extra safety: kill the global window.event
        if (window.event) {
            window.event.returnValue = false;
            window.event.cancelBubble = true;
        }
        return false;
    }

    var blocker = document.getElementById('blocker');

    // Override all drag/drop events on the blocker
    blocker.ondragover = function(e) { return killEvent(e); };
    blocker.ondragenter = function(e) {
        killEvent(e);
        iframe.contentWindow.postMessage({ type: 'dragenter' }, '*');
        return false;
    };
    blocker.ondragleave = function(e) {
        killEvent(e);
        iframe.contentWindow.postMessage({ type: 'dragleave' }, '*');
        return false;
    };
    blocker.ondrop = function(e) {
        killEvent(e);
        var evt = e || window.event;
        var dropData = { files: [], text: '', html: '' };
        if (evt && evt.dataTransfer) {
            if (evt.dataTransfer.files && evt.dataTransfer.files.length > 0) {
                dropData.files = Array.prototype.slice.call(evt.dataTransfer.files);
            }
            if (evt.dataTransfer.getData) {
                var plain = evt.dataTransfer.getData('Text');
                if (plain) dropData.text = plain;
                var html = evt.dataTransfer.getData('HTML');
                if (html) dropData.html = html;
            }
        }
        iframe.contentWindow.postMessage({
            type: 'drop',
            files: dropData.files,
            text: dropData.text,
            html: dropData.html
        }, '*');
        return false;
    };

    // Also protect the parent window
    window.ondragover = function(e) { return killEvent(e); };
    window.ondrop = function(e) { return killEvent(e); };
</script>
</body>
</html>