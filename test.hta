<!DOCTYPE html>
<html>
<head>
    <title>HTA Drop – No Iframe</title>
    <HTA:APPLICATION ID="app" APPLICATIONNAME="DropTest" />
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        html, body { width:100%; height:100%; overflow:hidden; }
        #container {
            width:100%;
            height:100%;
            overflow:auto;
            background:white;
        }
        /* Optional: make it look like an iframe */
        #contentDiv {
            width:100%;
            min-height:100%;
        }
    </style>
</head>
<body>
<div id="container">
    <div id="contentDiv"></div>
</div>

<script>
    // Load external HTML file into the div (works like an iframe)
    function loadPage(url) {
        var xhr = new XMLHttpRequest();
        xhr.open('GET', url, true);
        xhr.onreadystatechange = function() {
            if (xhr.readyState === 4 && xhr.status === 200) {
                document.getElementById('contentDiv').innerHTML = xhr.responseText;
                // Re‑execute any scripts inside the loaded HTML (optional)
                var scripts = document.getElementById('contentDiv').getElementsByTagName('script');
                for (var i = 0; i < scripts.length; i++) {
                    eval(scripts[i].text);
                }
            }
        };
        xhr.send();
    }

    // Load your main page
    loadPage('index2.html');

    // ----- Handle drops directly on the container (no iframe) -----
    var container = document.getElementById('container');

    function killEvent(e) {
        var evt = e || window.event;
        if (evt) {
            if (evt.preventDefault) evt.preventDefault();
            if (evt.stopPropagation) evt.stopPropagation();
            evt.returnValue = false;
            evt.cancelBubble = true;
        }
        if (window.event) {
            window.event.returnValue = false;
            window.event.cancelBubble = true;
        }
        return false;
    }

    container.ondragover = killEvent;
    container.ondrop = function(e) {
        killEvent(e);
        var evt = e || window.event;
        if (!evt || !evt.dataTransfer) return false;

        // Get dropped files
        var files = [];
        if (evt.dataTransfer.files && evt.dataTransfer.files.length > 0) {
            for (var i = 0; i < evt.dataTransfer.files.length; i++) {
                files.push(evt.dataTransfer.files[i]);
            }
        }

        // Get plain text
        var text = '';
        if (evt.dataTransfer.getData) {
            text = evt.dataTransfer.getData('Text') || '';
        }

        // Now you can pass this data to the loaded content
        // For example, call a global function in the loaded page
        if (window.handleDropInContent) {
            window.handleDropInContent(files, text);
        } else {
            alert('Dropped ' + files.length + ' file(s) and text: ' + text);
        }
        return false;
    };
</script>
</body>
</html>