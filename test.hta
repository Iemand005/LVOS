<!DOCTYPE html>
<html>
<head>
    <title>HTA Drop – No Iframe, No Access Denied</title>
    <HTA:APPLICATION ID="app" APPLICATIONNAME="DropTest" />
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        html, body { width:100%; height:100%; overflow:hidden; background:white; }
        #contentDiv { width:100%; height:100%; overflow:auto; }
    </style>
</head>
<body>
<div id="contentDiv"></div>

<script>
    // Use FileSystemObject to load the HTML file (no XHR, no security error)
    function loadLocalPage(filePath) {
        try {
            var fso = new ActiveXObject("Scripting.FileSystemObject");
            var file = fso.OpenTextFile(filePath, 1); // 1 = ForReading
            var htmlContent = file.ReadAll();
            file.Close();
            document.getElementById('contentDiv').innerHTML = htmlContent;
            // Re-run any scripts inside the loaded HTML (important)
            var scripts = document.getElementById('contentDiv').getElementsByTagName('script');
            for (var i = 0; i < scripts.length; i++) {
                eval(scripts[i].text);
            }
        } catch(e) {
            document.getElementById('contentDiv').innerHTML = '<h2>Error loading index.html</h2><p>' + e.message + '</p>';
        }
    }

    // Load your main page (adjust path if needed)
    loadLocalPage('index2.html');

    // ----- Handle drops on the main window (no iframe) -----
    function killEvent(e) {
        var evt = e || window.event;
        if (evt) {
            if (evt.preventDefault) evt.preventDefault();
            if (evt.stopPropagation) evt.stopPropagation();
            evt.returnValue = false;
            evt.cancelBubble = true;
        }
        if (window.event) {
            window.event.returnValue = false;
            window.event.cancelBubble = true;
        }
        return false;
    }

    // Block dragover on the whole window
    window.ondragover = killEvent;

    // Handle the drop event
    window.ondrop = function(e) {
        killEvent(e);
        var evt = e || window.event;
        if (!evt || !evt.dataTransfer) return false;

        // Extract files
        var files = [];
        if (evt.dataTransfer.files && evt.dataTransfer.files.length > 0) {
            for (var i = 0; i < evt.dataTransfer.files.length; i++) {
                files.push(evt.dataTransfer.files[i]);
            }
        }

        // Extract plain text
        var text = '';
        if (evt.dataTransfer.getData) {
            text = evt.dataTransfer.getData('Text') || '';
        }

        // Forward the drop data to the loaded content's global handler (if it exists)
        if (window.handleDropInContent) {
            window.handleDropInContent(files, text);
        } else {
            // Fallback: show an alert or write to a known element
            var out = document.getElementById('contentDiv').querySelector('#output');
            if (out) {
                out.innerHTML = '<strong>Dropped:</strong> ' + files.length + ' file(s) and text: ' + text;
            } else {
                alert('Dropped ' + files.length + ' file(s) and text: ' + text);
            }
        }
        return false;
    };
</script>
</body>
</html>