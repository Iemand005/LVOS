<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="x-ua-compatible" content="IE=edge">
    <title>My Drop-Enabled App</title>
    <hta:application id="oApp" applicationname="DropFix" scroll="no" windowstate="normal" />
    <style>
        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; }
        #dropLayer {
            position:absolute;
            inset:0;
            z-index:9999;
            background:rgba(0,0,0,0.25);
            color:white;
            display:none;
            align-items:center;
            justify-content:center;
            font-size:20px;
            font-family:sans-serif;
            pointer-events:auto;
        }
    </style>
</head>
<body ondragenter="alert('body ondragenter')" ondragover="event.preventDefault();" ondrop="alert('body ondrop'); event.preventDefault();">

    <iframe id="appFrame" src="index.html" style="width:100%; height:100%; border:none;"></iframe>
    <div id="dropLayer">Drop file here</div>

    <script>
        var dropLayer = null;
        var appFrame = null;

        function getFileUrl(filePath) {
            if (!filePath) return filePath;
            if (/^[a-zA-Z][a-zA-Z0-9+.-]*:/.test(filePath)) return filePath;
            return 'file:///' + filePath.replace(/\\/g, '/');
        }

        function dispatchToFrame(url) {
            try {
                var win = appFrame && appFrame.contentWindow;
                if (win && typeof win.handleDroppedFilePath === 'function') {
                    win.handleDroppedFilePath(url);
                    return true;
                }
            } catch (e) {
                console.warn('Dispatch error:', e);
            }
            return false;
        }

        function onDropFile(event) {
            alert('onDropFile event');
            event.preventDefault();
            event.stopPropagation();
            dropLayer.style.display = 'none';
            var dt = event.dataTransfer;
            if (!dt) {
                alert('drop event had no dataTransfer');
                return;
            }
            var files = dt.files;
            if (!files || files.length === 0) {
                alert('drop event had no files');
                return;
            }
            var file = files[0];
            var path = file.path || file.fileName || file.fullPath || file.name;
            if (!path) {
                alert('file path unavailable');
                return;
            }
            var fileUrl = getFileUrl(path);
            alert('File drop detected: ' + fileUrl);
            if (!dispatchToFrame(fileUrl)) {
                console.log('Frame handler not ready, retained drop:', fileUrl);
            }
        }

        function showDropLayer(event) {
            alert('showDropLayer event: ' + event.type);
            event.preventDefault();
            event.stopPropagation();
            dropLayer.style.display = 'flex';
            if (event.dataTransfer) event.dataTransfer.dropEffect = 'copy';
        }

        function hideDropLayer(event) {
            alert('hideDropLayer event: ' + event.type);
            event.preventDefault();
            event.stopPropagation();
            dropLayer.style.display = 'none';
        }

        window.onload = function() {
            dropLayer = document.getElementById('dropLayer');
            appFrame = document.getElementById('appFrame');

            if (dropLayer) {
                dropLayer.addEventListener('dragenter', showDropLayer, false);
                dropLayer.addEventListener('dragover', showDropLayer, false);
                dropLayer.addEventListener('drop', onDropFile, false);
                dropLayer.addEventListener('dragleave', hideDropLayer, false);
            }

            window.addEventListener('dragenter', showDropLayer, false);
            window.addEventListener('dragover', showDropLayer, false);
            window.addEventListener('drop', onDropFile, false);

            document.body.addEventListener('dragenter', showDropLayer, false);
            document.body.addEventListener('dragover', showDropLayer, false);
            document.body.addEventListener('drop', onDropFile, false);
            appFrame.addEventListener('dragenter', showDropLayer, false);
            appFrame.addEventListener('dragover', showDropLayer, false);
            appFrame.addEventListener('drop', onDropFile, false);
        };
    </script>
</body>
</html>
